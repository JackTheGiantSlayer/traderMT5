//@version=6
// © เทรดตามรายใหญ่ 2026
indicator("Demo PJ V.01.04", overlay=true, max_labels_count=500, max_boxes_count=500, max_lines_count=500, max_bars_back=1000)

// COLORS
color c_gold      = #D4AF37
color c_turquoise = #40E0D0
color c_black     = #111111
color c_panel     = #1A1A1A
color c_white     = #FFFFFF
color c_green     = #00C853
color c_red       = #FF1744
color c_gray      = #8E8E8E
color c_blue      = #2196F3
color c_orange    = #FF6D00

// INPUTS
groupVis      = "Visuals & Premium UI"
dashTextSize  = input.string("small", "Dashboard Font Size", options=["tiny","small","normal"], group=groupVis)
tradeTextSize = input.string("small", "Trade Label Size", options=["tiny","small","normal"], group=groupVis)
labelOffset   = input.int(12, "Label Right Offset", minval=1, group=groupVis)
showPremiumBg = input.bool(true, "Show Premium Background Glow", group=groupVis)
showBB        = input.bool(true, "Show BB14", group=groupVis)
showRibbon    = input.bool(true, "Show Premium Trend Ribbon", group=groupVis)
showHistory   = input.bool(true, "Show Last 10 Signal History", group=groupVis)

groupRisk  = "Risk Management"
tpMode     = input.string("Risk-Reward (ATR)", "TP/SL Calculation Mode", options=["Risk-Reward (ATR)", "Fixed Points"], group=groupRisk)
atrMult    = input.float(1.5, "SL ATR14 Multiplier (Base)", minval=0.1, step=0.1, group=groupRisk)
useDynATR  = input.bool(true, "Dynamic ATR Multiplier", group=groupRisk)
tp1RR      = input.float(1.0, "TP1 RR Multiplier", minval=0.1, step=0.1, group=groupRisk)
tp2RR      = input.float(2.0, "TP2 RR Multiplier", minval=0.1, step=0.1, group=groupRisk)
tp3RR      = input.float(3.0, "TP3 RR Multiplier", minval=0.1, step=0.1, group=groupRisk)

// Fixed Points inputs
slPoints   = input.float(100.0, "Fixed SL Points (Fixed Mode)", minval=1.0, step=10.0, group=groupRisk)
tp1Points  = input.float(100.0, "Fixed TP1 Points (Fixed Mode)", minval=1.0, step=10.0, group=groupRisk)
tp2Points  = input.float(200.0, "Fixed TP2 Points (Fixed Mode)", minval=1.0, step=10.0, group=groupRisk)
tp3Points  = input.float(300.0, "Fixed TP3 Points (Fixed Mode)", minval=1.0, step=10.0, group=groupRisk)

groupSig      = "Signal Filter"
minScore      = input.int(6, "Minimum Trend Score 0-10", minval=1, maxval=10, group=groupSig)
useVolume     = input.bool(false, "Use Volume Filter", group=groupSig)
volMultiplier = input.float(2.0, "High Volume Multiplier", minval=1.0, step=0.1, group=groupSig)
vwapAnchor    = input.string("Session", "VWAP Anchor", options=["Session","Week","Month"], group=groupSig)

// FUNCTIONS
f_addDashRow(_table, _row, _title, _val, _col, _size) =>
    table.cell(_table, 0, _row, _title, text_color=c_white, text_halign=text.align_left, text_size=_size)
    table.cell(_table, 1, _row, _val, text_color=_col, text_halign=text.align_right, text_size=_size)

f_status(_bull, _bear) =>
    _bull ? "BULL" : _bear ? "BEAR" : "NEUTRAL"

f_statusColor(_bull, _bear) =>
    _bull ? c_green : _bear ? c_red : c_gray

f_h1_macdBull() =>
    [ml, ms, mh] = ta.macd(close, 15, 35, 9)
    ml > ms

// INDICATORS
ema14  = ta.ema(close, 14)
atr14  = ta.atr(14)
rsi14  = ta.rsi(close, 14)

[macdLine, macdSignal, macdHist] = ta.macd(close, 15, 35, 9)

stochRaw = ta.stoch(close, high, low, 9)
stochK   = ta.sma(stochRaw, 3)
stochD   = ta.sma(stochK, 3)

[bbBasis, bbUpper, bbLower] = ta.bb(close, 14, 2.0)

bool newWeek  = timeframe.change("W")
bool newMonth = timeframe.change("M")
vwapVal = vwapAnchor == "Week" ? ta.vwap(hlc3, newWeek) : vwapAnchor == "Month" ? ta.vwap(hlc3, newMonth) : ta.vwap(hlc3)

volAvg  = ta.sma(volume, 20)
highVol = volume > volAvg * volMultiplier

// DYNAMIC ATR
atrSma      = ta.sma(atr14, 50)
atrRatio    = atr14 / atrSma
dynamicMult = useDynATR ? (atrRatio > 1.5 ? atrMult * 0.8 : atrRatio < 0.7 ? atrMult * 1.2 : atrMult) : atrMult
atrStatus   = atrRatio > 1.0 ? "HIGH VOL" : "NORMAL"

// TREND ENGINE
emaBull   = close > ema14
emaBear   = close < ema14
rsiBull   = rsi14 > 55
rsiBear   = rsi14 < 45
macdBull  = macdLine > macdSignal
macdBear  = macdLine < macdSignal
stochBull = stochK > stochD and stochK > 50
stochBear = stochK < stochD and stochK < 50
bbBull    = close > bbBasis
bbBear    = close < bbBasis
vwapBull  = close > vwapVal
vwapBear  = close < vwapVal

bullScore = (emaBull ? 2 : 0) + (vwapBull ? 2 : 0) + (macdBull ? 2 : 0) + (rsiBull ? 2 : 0) + (stochBull ? 1 : 0) + (bbBull ? 1 : 0)
bearScore = (emaBear ? 2 : 0) + (vwapBear ? 2 : 0) + (macdBear ? 2 : 0) + (rsiBear ? 2 : 0) + (stochBear ? 1 : 0) + (bbBear ? 1 : 0)

bullPct = bullScore / 10.0 * 100
bearPct = bearScore / 10.0 * 100

trendBull = bullScore >= minScore and bullScore > bearScore
trendBear = bearScore >= minScore and bearScore > bullScore

trendText = trendBull ? "UPTREND" : trendBear ? "DOWNTREND" : "SIDEWAY"
trendCol  = trendBull ? c_green : trendBear ? c_red : c_gold

// H1 MULTI-TIMEFRAME
h1_close    = request.security(syminfo.tickerid, "60", close[1],             lookahead=barmerge.lookahead_off)
h1_ema14    = request.security(syminfo.tickerid, "60", ta.ema(close, 14)[1], lookahead=barmerge.lookahead_off)
h1_rsi14    = request.security(syminfo.tickerid, "60", ta.rsi(close, 14)[1], lookahead=barmerge.lookahead_off)
h1_vwap     = request.security(syminfo.tickerid, "60", ta.vwap(hlc3)[1],     lookahead=barmerge.lookahead_off)
h1_macdBull = request.security(syminfo.tickerid, "60", f_h1_macdBull()[1],   lookahead=barmerge.lookahead_off)

h1_emaBull  = h1_close > h1_ema14
h1_rsiBull  = h1_rsi14 > 55
h1_rsiBear  = h1_rsi14 < 45
h1_vwapBull = h1_close > h1_vwap

h1_bullCount = (h1_emaBull ? 1 : 0) + (h1_rsiBull ? 1 : 0) + (h1_macdBull ? 1 : 0) + (h1_vwapBull ? 1 : 0)
h1_bearCount = (not h1_emaBull ? 1 : 0) + (h1_rsiBear ? 1 : 0) + (not h1_macdBull ? 1 : 0) + (not h1_vwapBull ? 1 : 0)

h1_trendBull = h1_bullCount >= 3
h1_trendBear = h1_bearCount >= 3
h1_trendText = h1_trendBull ? "UPTREND" : h1_trendBear ? "DOWNTREND" : "SIDEWAY"
h1_trendCol  = h1_trendBull ? c_green : h1_trendBear ? c_red : c_gold

mtfConfirm     = (trendBull and h1_trendBull) or (trendBear and h1_trendBear)
mtfConfirmText = mtfConfirm ? "CONFIRMED" : "NOT MATCH"
mtfConfirmCol  = mtfConfirm ? c_green : c_red

// SIGNAL LOGIC
emaCrossUp     = ta.crossover(close, ema14)
emaCrossDown   = ta.crossunder(close, ema14)
macdCrossUp    = ta.crossover(macdLine, macdSignal)
macdCrossDown  = ta.crossunder(macdLine, macdSignal)
stochCrossUp   = ta.crossover(stochK, stochD)
stochCrossDown = ta.crossunder(stochK, stochD)

buySignalRaw  = trendBull[1] and (emaCrossUp[1] or macdCrossUp[1] or stochCrossUp[1])
sellSignalRaw = trendBear[1] and (emaCrossDown[1] or macdCrossDown[1] or stochCrossDown[1])

buySignal  = useVolume ? buySignalRaw and highVol[1] : buySignalRaw
sellSignal = useVolume ? sellSignalRaw and highVol[1] : sellSignalRaw

// SIGNAL STATE
var int lastSignalState = 0

triggerBuy  = buySignal  and lastSignalState != 1
triggerSell = sellSignal and lastSignalState != -1

// TRADE SETUP
var float entryP = na
var float slP    = na
var float tp1    = na
var float tp1_5  = na
var float tp2    = na
var float tp2_5  = na
var float tp3    = na
var bool tp1Hit  = false
var bool tp1_5Hit = false
var bool tp2Hit  = false
var bool tp2_5Hit = false
var bool tp3Hit  = false
var bool slHit   = false

if triggerBuy or triggerSell
    lastSignalState := triggerBuy ? 1 : -1
    entryP := close[1]
    
    if tpMode == "Risk-Reward (ATR)"
        risk = atr14[1] * dynamicMult
        slP := triggerBuy ? entryP - risk : entryP + risk
        tp1 := triggerBuy ? entryP + risk * tp1RR : entryP - risk * tp1RR
        tp2 := triggerBuy ? entryP + risk * tp2RR : entryP - risk * tp2RR
        tp3 := triggerBuy ? entryP + risk * tp3RR : entryP - risk * tp3RR
    else
        slDiff = slPoints * syminfo.mintick
        tp1Diff = tp1Points * syminfo.mintick
        tp2Diff = tp2Points * syminfo.mintick
        tp3Diff = tp3Points * syminfo.mintick
        
        slP := triggerBuy ? entryP - slDiff : entryP + slDiff
        tp1 := triggerBuy ? entryP + tp1Diff : entryP - tp1Diff
        tp2 := triggerBuy ? entryP + tp2Diff : entryP - tp2Diff
        tp3 := triggerBuy ? entryP + tp3Diff : entryP - tp3Diff

    tp1_5 := (tp1 + tp2) / 2
    tp2_5 := (tp2 + tp3) / 2
    
    tp1Hit := false
    tp1_5Hit := false
    tp2Hit := false
    tp2_5Hit := false
    tp3Hit := false
    slHit  := false

// HIT DETECTION
if lastSignalState == 1 and not na(entryP)
    if low <= slP
        slHit           := true
        tp1Hit          := false
        tp1_5Hit        := false
        tp2Hit          := false
        tp2_5Hit        := false
        tp3Hit          := false
        lastSignalState := 0
    else
        if high >= tp1
            tp1Hit := true
        if tp1Hit and high >= tp1_5
            tp1_5Hit := true
        if tp1_5Hit and high >= tp2
            tp2Hit := true
        if tp2Hit and high >= tp2_5
            tp2_5Hit := true
        if tp2_5Hit and high >= tp3
            tp3Hit := true

if lastSignalState == -1 and not na(entryP)
    if high >= slP
        slHit           := true
        tp1Hit          := false
        tp1_5Hit        := false
        tp2Hit          := false
        tp2_5Hit        := false
        tp3Hit          := false
        lastSignalState := 0
    else
        if low <= tp1
            tp1Hit := true
        if tp1Hit and low <= tp1_5
            tp1_5Hit := true
        if tp1_5Hit and low <= tp2
            tp2Hit := true
        if tp2Hit and low <= tp2_5
            tp2_5Hit := true
        if tp2_5Hit and low <= tp3
            tp3Hit := true

// VISUALS
bgCol = trendBull ? color.new(c_green, 92) : trendBear ? color.new(c_red, 92) : color.new(c_gold, 96)
bgcolor(showPremiumBg ? bgCol : na)

emaColor = trendBull ? c_gold : trendBear ? c_red : c_gray
plotEma  = plot(ema14, "EMA14 Premium", color=emaColor, linewidth=2)
plotMid  = plot(bbBasis, "BB14 Basis", color=color.new(c_white, 70), linewidth=1, display=showBB ? display.all : display.none)

plot(showBB ? bbUpper : na, "BB14 Upper", color=color.new(c_blue, 60))
plot(showBB ? bbLower : na, "BB14 Lower", color=color.new(c_blue, 60))

ribbonCol = trendBull ? color.new(c_gold, 82) : trendBear ? color.new(c_red, 85) : color.new(c_gray, 90)
fill(plotEma, plotMid, color=showRibbon ? ribbonCol : na)

barCol = highVol ? c_gold : trendBull ? color.new(c_green, 35) : trendBear ? color.new(c_red, 35) : na
barcolor(barCol)

// SIGNAL ARROW (ไม่มีข้อความ ย้ายไปใน history label แทน)
plotshape(triggerBuy,  title="BUY",  text="BUY",  style=shape.labelup,   location=location.belowbar, color=c_gold,   textcolor=c_black, size=size.small)
plotshape(triggerSell, title="SELL", text="SELL", style=shape.labeldown, location=location.abovebar, color=c_orange, textcolor=c_white, size=size.small)

// HISTORY LABEL — แสดง 10 Signal ล่าสุด
var label[] histLabels = array.new_label()

if (triggerBuy or triggerSell) and showHistory
    isBuy   = triggerBuy
    _entry  = close[1]
    
    float _sl = na
    float _tp1 = na
    float _tp2 = na
    float _tp3 = na
    
    if tpMode == "Risk-Reward (ATR)"
        _risk   = atr14[1] * dynamicMult
        _sl     := isBuy ? _entry - _risk : _entry + _risk
        _tp1    := isBuy ? _entry + _risk * tp1RR  : _entry - _risk * tp1RR
        _tp2    := isBuy ? _entry + _risk * tp2RR  : _entry - _risk * tp2RR
        _tp3    := isBuy ? _entry + _risk * tp3RR  : _entry - _risk * tp3RR
    else
        _slDiff = slPoints * syminfo.mintick
        _tp1Diff = tp1Points * syminfo.mintick
        _tp2Diff = tp2Points * syminfo.mintick
        _tp3Diff = tp3Points * syminfo.mintick
        
        _sl     := isBuy ? _entry - _slDiff : _entry + _slDiff
        _tp1    := isBuy ? _entry + _tp1Diff : _entry - _tp1Diff
        _tp2    := isBuy ? _entry + _tp2Diff : _entry - _tp2Diff
        _tp3    := isBuy ? _entry + _tp3Diff : _entry - _tp3Diff
        
    _tp1_5  = (_tp1 + _tp2) / 2
    _tp2_5  = (_tp2 + _tp3) / 2

    _side   = isBuy ? "BUY" : "SELL"
    _txt    = _side + "\n" +
              "E  : " + str.tostring(_entry, "#.##") + "\n" +
              "SL : " + str.tostring(_sl,    "#.##") + "\n" +
              "TP1: " + str.tostring(_tp1,   "#.##") + "\n" +
              "TP1.5: " + str.tostring(_tp1_5, "#.##") + "\n" +
              "TP2: " + str.tostring(_tp2,   "#.##") + "\n" +
              "TP2.5: " + str.tostring(_tp2_5, "#.##") + "\n" +
              "TP3: " + str.tostring(_tp3,   "#.##")

    _yPos   = isBuy ? low  - atr14 * 0.5 : high + atr14 * 0.5
    _bgCol  = isBuy ? c_gold : c_orange
    _txCol  = isBuy ? c_black : c_white
    _style  = isBuy ? label.style_label_up : label.style_label_down

    _lbl = label.new(bar_index, _yPos, _txt, color=_bgCol, textcolor=_txCol, style=_style, size=tradeTextSize, textalign=text.align_left)
    array.push(histLabels, _lbl)

    // เก็บแค่ 10 label ล่าสุด ลบอันเก่าทิ้ง
    if array.size(histLabels) > 10
        label.delete(array.shift(histLabels))

// CURRENT TRADE LINES + LABELS
var line lEntry = na
var line lSL    = na
var line lTP1   = na
var line lTP1_5 = na
var line lTP2   = na
var line lTP2_5 = na
var line lTP3   = na

var label lbEntry = label.new(na, na, "", color=c_gold,      textcolor=c_black, style=label.style_label_left, size=tradeTextSize)
var label lbSL    = label.new(na, na, "", color=c_red,       textcolor=c_white, style=label.style_label_left, size=tradeTextSize)
var label lbTP1   = label.new(na, na, "", color=c_green,     textcolor=c_white, style=label.style_label_left, size=tradeTextSize)
var label lbTP1_5 = label.new(na, na, "", color=c_green,     textcolor=c_white, style=label.style_label_left, size=tradeTextSize)
var label lbTP2   = label.new(na, na, "", color=c_green,     textcolor=c_white, style=label.style_label_left, size=tradeTextSize)
var label lbTP2_5 = label.new(na, na, "", color=c_green,     textcolor=c_white, style=label.style_label_left, size=tradeTextSize)
var label lbTP3   = label.new(na, na, "", color=c_turquoise, textcolor=c_black, style=label.style_label_left, size=tradeTextSize)

if triggerBuy or triggerSell
    line.delete(lEntry)
    line.delete(lSL)
    line.delete(lTP1)
    line.delete(lTP1_5)
    line.delete(lTP2)
    line.delete(lTP2_5)
    line.delete(lTP3)
    lEntry := line.new(bar_index, entryP, bar_index + 20, entryP, color=c_white,     width=2, extend=extend.right)
    lSL    := line.new(bar_index, slP,    bar_index + 20, slP,    color=c_red,       width=2, style=line.style_solid,  extend=extend.right)
    lTP1   := line.new(bar_index, tp1,    bar_index + 20, tp1,    color=c_green,     width=1, style=line.style_dashed, extend=extend.right)
    lTP1_5 := line.new(bar_index, tp1_5,  bar_index + 20, tp1_5,  color=c_green,     width=1, style=line.style_dotted, extend=extend.right)
    lTP2   := line.new(bar_index, tp2,    bar_index + 20, tp2,    color=c_green,     width=2, style=line.style_dashed, extend=extend.right)
    lTP2_5 := line.new(bar_index, tp2_5,  bar_index + 20, tp2_5,  color=c_green,     width=2, style=line.style_dotted, extend=extend.right)
    lTP3   := line.new(bar_index, tp3,    bar_index + 20, tp3,    color=c_turquoise, width=3, style=line.style_solid,  extend=extend.right)

if lastSignalState != 0 and not na(entryP)
    int x    = bar_index + labelOffset
    sideText = lastSignalState == 1 ? "BUY" : "SELL"
    line.set_color(lTP1, tp1Hit ? c_turquoise : c_green)
    line.set_color(lTP1_5, tp1_5Hit ? c_turquoise : c_green)
    line.set_color(lTP2, tp2Hit ? c_turquoise : c_green)
    line.set_color(lTP2_5, tp2_5Hit ? c_turquoise : c_green)
    line.set_color(lTP3, tp3Hit ? c_gold      : c_turquoise)
    line.set_color(lSL,  slHit  ? c_red       : color.new(c_red, 0))
    label.set_xy(lbEntry, x, entryP)
    label.set_text(lbEntry, sideText + " ENTRY : " + str.tostring(entryP, "#.##"))
    label.set_xy(lbSL, x, slP)
    label.set_text(lbSL, "SL : " + str.tostring(slP, "#.##") + (slHit ? " [X]" : ""))
    label.set_xy(lbTP1, x, tp1)
    label.set_text(lbTP1, "TP1 : " + str.tostring(tp1, "#.##") + (tp1Hit ? " [OK]" : ""))
    label.set_xy(lbTP1_5, x, tp1_5)
    label.set_text(lbTP1_5, "TP1.5 : " + str.tostring(tp1_5, "#.##") + (tp1_5Hit ? " [OK]" : ""))
    label.set_xy(lbTP2, x, tp2)
    label.set_text(lbTP2, "TP2 : " + str.tostring(tp2, "#.##") + (tp2Hit ? " [OK]" : ""))
    label.set_xy(lbTP2_5, x, tp2_5)
    label.set_text(lbTP2_5, "TP2.5 : " + str.tostring(tp2_5, "#.##") + (tp2_5Hit ? " [OK]" : ""))
    label.set_xy(lbTP3, x, tp3)
    label.set_text(lbTP3, "TP3 : " + str.tostring(tp3, "#.##") + (tp3Hit ? " [!!]" : ""))

// DASHBOARD
var table d = table.new(position.top_right, 2, 16, bgcolor=color.new(c_panel, 8), border_width=1, border_color=c_gold)

if barstate.islast
    table.cell(d, 0, 0, "Demo PJ V.01.03", text_color=c_black, bgcolor=c_gold, text_size=dashTextSize)
    table.cell(d, 1, 0, trendText, text_color=c_black, bgcolor=c_gold, text_size=dashTextSize)
    f_addDashRow(d,  1, "Trend Score", str.tostring(bullScore) + "B / " + str.tostring(bearScore) + "S (max10)", trendCol, dashTextSize)
    f_addDashRow(d,  2, "Bull Power",  str.tostring(bullPct, "#") + "%", bullPct >= 60 ? c_green : c_gray, dashTextSize)
    f_addDashRow(d,  3, "ATR14",       str.tostring(atr14, "#.##") + " / " + atrStatus, c_gold, dashTextSize)
    f_addDashRow(d,  4, "ATR Mult",    str.tostring(dynamicMult, "#.##") + "x", c_gold, dashTextSize)
    f_addDashRow(d,  5, "RSI14",       str.tostring(rsi14, "#.#"), rsiBull ? c_green : rsiBear ? c_red : c_gold, dashTextSize)
    f_addDashRow(d,  6, "MACD",        f_status(macdBull, macdBear), f_statusColor(macdBull, macdBear), dashTextSize)
    f_addDashRow(d,  7, "Stoch",       str.tostring(stochK, "#.#") + " / " + str.tostring(stochD, "#.#"), f_statusColor(stochBull, stochBear), dashTextSize)
    f_addDashRow(d,  8, "BB14",        close > bbUpper ? "OVER BUY" : close < bbLower ? "OVER SELL" : f_status(bbBull, bbBear), f_statusColor(bbBull, bbBear), dashTextSize)
    f_addDashRow(d,  9, "EMA14",       f_status(emaBull, emaBear), f_statusColor(emaBull, emaBear), dashTextSize)
    f_addDashRow(d, 10, "VWAP",        f_status(vwapBull, vwapBear), f_statusColor(vwapBull, vwapBear), dashTextSize)
    table.cell(d, 0, 11, "-- Multi-Timeframe --", text_color=c_gold, text_halign=text.align_left, text_size=dashTextSize)
    table.cell(d, 1, 11, "", text_size=dashTextSize)
    f_addDashRow(d, 12, "H1 Trend",    h1_trendText, h1_trendCol, dashTextSize)
    f_addDashRow(d, 13, "H1 Score",    str.tostring(h1_bullCount) + "B / " + str.tostring(h1_bearCount) + "S (max4)", h1_trendCol, dashTextSize)
    f_addDashRow(d, 14, "MTF Confirm", mtfConfirmText, mtfConfirmCol, dashTextSize)
    f_addDashRow(d, 15, "Signal",      triggerBuy ? "NEW BUY" : triggerSell ? "NEW SELL" : "WAIT", triggerBuy ? c_green : triggerSell ? c_red : c_gold, dashTextSize)

// ALERTS
alertcondition(triggerBuy,                 title="BUY SIGNAL",         message="Demo PJ: BUY Signal")
alertcondition(triggerSell,                title="SELL SIGNAL",        message="Demo PJ: SELL Signal")
alertcondition(triggerBuy and mtfConfirm,  title="BUY MTF CONFIRMED",  message="Demo PJ: BUY - H1 Confirmed!")
alertcondition(triggerSell and mtfConfirm, title="SELL MTF CONFIRMED", message="Demo PJ: SELL - H1 Confirmed!")
alertcondition(tp1Hit,                     title="TP1 HIT",            message="Demo PJ: TP1 Hit")
alertcondition(tp1_5Hit,                   title="TP1.5 HIT",          message="Demo PJ: TP1.5 Hit")
